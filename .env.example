DATABASE_URL="postgresql://tuition:tuition@localhost:5432/tuition_db"
DIRECT_DATABASE_URL="postgresql://tuition:tuition@localhost:5432/tuition_db"
MANAGER_EMAILS="manager@example.com"
OWNER_MANAGER_EMAIL="owner@example.com"
CRON_SECRET="change-me-in-production"
OPENCLAW_OPS_KEY="change-me-in-production"
OPENCLAW_OPS_IP_ALLOWLIST="127.0.0.1,::1,localhost"

# Shared docs storage: "s3" (recommended) or "local"
SHARED_DOC_STORAGE_DRIVER="s3"
SHARED_DOC_S3_BUCKET="your-shared-doc-bucket"
SHARED_DOC_S3_REGION="ap-southeast-1"
# Optional for S3-compatible providers like COS/MinIO
SHARED_DOC_S3_ENDPOINT=""
SHARED_DOC_S3_FORCE_PATH_STYLE="true"
SHARED_DOC_S3_ACCESS_KEY_ID=""
SHARED_DOC_S3_SECRET_ACCESS_KEY=""
