flowchart TD
    A["家长 / 学生 / 合作方 / 老师 发来需求"] --> B["Emily 收集信息"]
    B --> C{"信息是否完整?"}
    C -- "否" --> D["Emily 补信息\n- 学生姓名\n- 课程/科目\n- 老师\n- 时间需求\n- 截止时间\n- 证据截图"]
    D --> C
    C -- "是" --> E["Emily 判断事项类型"]

    E --> E1["新排课 / 改课 / 补课加课 / 取消请假 / 新学生购买课包 / 合作方调整 / 需管理介入"]
    E1 --> F["Emily 录入工单"]
    F --> G["Emily 设置\n- 工单类型\n- 优先级\n- 状态\n- 负责人\n- Situation 三项"]
    G --> H["Emily 把可执行工单交给 Eva"]

    H --> I{"Eva 检查工单是否足够执行?"}
    I -- "否" --> J["Eva 退回 Emily\n写明缺什么信息 / 为什么不能做"]
    J --> D
    I -- "是" --> K["Eva 在系统执行"]

    K --> K1["系统动作示例\n- 排课 / 改时间\n- 改老师\n- 加学生进班\n- 调整报名\n- 更新课时包信息\n- 备注/状态更新"]
    K1 --> L{"执行中是否遇到卡点?"}

    L -- "老师未回复 / 无可排时间" --> M["Emily 联系老师确认"]
    M --> N{"老师是否确认?"}
    N -- "否" --> O["升级给管理\n说明卡点和截止时间"]
    N -- "是" --> K

    L -- "涉及收费 / 课包 / 收据 / 结算" --> P["财务支持"]
    P --> P1["财务动作\n- 生成收款单\n- 建立/核对课时包\n- 收据审批\n- 合作方结算支持"]
    P1 --> Q{"财务信息是否齐全?"}
    Q -- "否" --> R["退回 Emily / Eva 补资料"]
    R --> D
    Q -- "是" --> K

    L -- "涉及异常 / 权限不足 / 投诉 / 管理判断" --> O
    L -- "无卡点" --> S["Eva 回填工单处理结果"]

    O --> O1["管理动作\n- 拍板是否继续\n- 指定负责人\n- 处理争议\n- 确认延期原因"]
    O1 --> T{"管理决定"}
    T -- "继续执行" --> K
    T -- "暂停 / 待观察" --> U["工单保持未完成\n写明原因和下一步"]
    T -- "结束 / 无需继续" --> V["工单取消并归档"]

    S --> W{"是否已完全处理?"}
    W -- "是" --> X["Eva 点击完成"]
    X --> Y["Eva 归档工单"]
    W -- "否" --> U

    U --> Z["Emily 每日收工前汇总未完成工单"]
    Z --> Z1["发送给管理\n- 为什么没完成\n- 卡点\n- 谁跟进\n- 明日动作"]
    Y --> AA["当日闭环完成"]

    M -. "老师侧后续动作" .-> AB["老师上课 / 提交反馈 / 更新可上课时间"]
