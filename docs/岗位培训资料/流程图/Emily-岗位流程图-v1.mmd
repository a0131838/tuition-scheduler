flowchart TD
    A["收到家长 / 学生 / 合作方 / 老师消息"] --> B["判断是否需要工单"]
    B --> C["录入工单"]
    C --> D["补齐信息和证据"]
    D --> E["写清 Situation 三项"]
    E --> F["交给 Eva 执行"]
    F --> G{"Eva 是否退回补资料?"}
    G -- "是" --> H["继续补信息"]
    H --> F
    G -- "否" --> I["白天持续催进度"]
    I --> J{"是否卡住?"}
    J -- "否" --> K["等待 Eva 完成并回填"]
    J -- "是" --> L["联系老师 / 家长 / 合作方"]
    L --> M{"仍未解决?"}
    M -- "是" --> N["升级给管理"]
    M -- "否" --> F
    K --> O["收工前汇总未完成工单"]
    N --> O
