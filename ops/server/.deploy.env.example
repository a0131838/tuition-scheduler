# Copy to: ops/server/.deploy.env
# Fill values before running scripts.

APP_NAME=tuition-scheduler
APP_DIR=/opt/tuition-scheduler
REPO_URL=https://github.com/a0131838/tuition-scheduler.git
BRANCH=master
DEPLOY_USER=deploy
APP_PORT=3000
DOMAIN=app.example.com
LETSENCRYPT_EMAIL=ops@example.com

# Required app env
NEXT_PUBLIC_APP_URL=https://app.example.com
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
MANAGER_EMAILS=manager1@example.com,manager2@example.com
OWNER_MANAGER_EMAIL=owner@example.com
CRON_SECRET=replace-with-strong-random-secret

# Optional alerts (shared by monitor + ledger integrity job)
# WeCom bot webhook example:
# ALERT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxx
ALERT_WEBHOOK_URL=
# Optional local mail alert target (requires `mail` command on server)
ALERT_EMAIL_TO=

# Shared docs (COS/S3)
SHARED_DOC_STORAGE_DRIVER=s3
SHARED_DOC_S3_BUCKET=your-bucket-1234567890
SHARED_DOC_S3_REGION=ap-hongkong
SHARED_DOC_S3_ENDPOINT=https://cos.ap-hongkong.myqcloud.com
SHARED_DOC_S3_FORCE_PATH_STYLE=false
SHARED_DOC_S3_ACCESS_KEY_ID=AKIDxxxxxxxxxxxxxxxxxxxx
SHARED_DOC_S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx

# Optional for first deploy
RUN_SEED=false

# Deployment safety
# true: remove stale untracked files before build (recommended)
CLEAN_UNTRACKED=true
# true: bypass release doc gate (only for emergency hotfix)
SKIP_RELEASE_DOC_CHECK=false

# Production safety fuse
# Keep false in production. Set true only for local/dev test deploys.
ALLOW_LOCAL_DB_IN_PROD=false
